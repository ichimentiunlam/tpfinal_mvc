<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Arcade de Preguntas - Challenge Hub</title>
    <link rel="icon" type="image/x-icon" href="/tpfinal_mvc/assets/img/favicon.ico">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/tpfinal_mvc/assets/Css/style.css">
    <style>
        header {
            background: rgba(4, 4, 10, 0.92);
            border-bottom: 1px solid rgba(124, 77, 255, 0.28);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
            backdrop-filter: blur(14px);
        }

        nav ul.nav_links li a {
            transition: text-shadow 0.22s ease, color 0.18s ease;
        }

        nav ul.nav_links li a:hover,
        nav ul.nav_links li a:focus {
            color: #00e676;
            text-shadow: 0 0 10px #00e676;
        }
    </style>

</head>
<body>

<header>
    <a class="logo" href="/tpfinal_mvc/User/home"><img src="/tpfinal_mvc/assets/Img/logo.png" alt="Logo"></a>
    
    <nav>
        <ul class="nav_links">
            <li><a href="/tpfinal_mvc/User/home">Inicio</a></li>
            {{^loggedIn}}
            <li><a href="/tpfinal_mvc/User/registro">Registro</a></li>
            <li><a href="/tpfinal_mvc/User/login">Login</a></li>
            {{/loggedIn}}
            {{#loggedIn}}
            <li><a href="/tpfinal_mvc/User/perfil">Mi perfil</a></li>
            <li><a href="/tpfinal_mvc/Game/lobby">Lobby</a></li>
            <li><a href="/tpfinal_mvc/Game/ranking">Ranking</a></li>
            {{#esAdmin}}
            <li><a href="/tpfinal_mvc/Admin/estadisticas">Estadisticas</a></li>
            {{/esAdmin}}

            {{#esEditor}}
            <li><a href="/tpfinal_mvc/Editor/modificar">Modificar</a></li>
            <li><a href="/tpfinal_mvc/Editor/correo">Correo</a></li>
            {{/esEditor}}
            <li><a href="/tpfinal_mvc/User/logout">Salir</a></li>
            {{/loggedIn}}
        </ul>
    </nav>
    

    {{#loggedIn}}
    <div class="user-badge">
        Hola, {{username}}. {{^validated}}Tu correo aún no está validado.{{/validated}}{{#validated}}Tu correo está validado.{{/validated}}
    </div>
    {{/loggedIn}}
</header>

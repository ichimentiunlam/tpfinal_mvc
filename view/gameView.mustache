{{>header}}
<link rel="stylesheet" href="/tpfinal_mvc/assets/Css/game.css">

<style>
    /* CSS para el texto +25 animado */
    .timer-bonus {
        opacity: 0;
        color: #00e676; /* Verde bien chillón */
        font-weight: 900;
        font-size: 1.8rem;
        position: absolute;
        transform: translateY(10px);
        transition: all 0.8s ease-out;
        pointer-events: none;
    }
    .timer-bonus.visible {
        opacity: 1;
        transform: translateY(-30px);
    }
    
    /* Comodines bottom panel */
    .arcade-card {
        background: rgba(8, 8, 14, 0.95);
        border: 2px solid rgba(124, 77, 255, 0.6);
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.45), inset 0 0 28px rgba(124, 77, 255, 0.14);
        border-radius: 30px;
        position: relative;
        overflow: visible;
        padding: 32px;
    }

    .arcade-card h2,
    .categoria-chip,
    .answer-btn {
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.08);
    }

    .wildcard-panel-bottom {
        margin-top: 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
    }
    #wildcardToggle {
        background: rgba(5, 5, 10, 0.96);
        color: #fff;
        font-size: 0.95rem;
        font-weight: 800;
        padding: 16px 18px;
        border: 1px solid rgba(0, 230, 118, 0.8);
        border-radius: 28px 0 0 28px;
        cursor: pointer;
        box-shadow: 0 0 26px rgba(0, 230, 118, 0.28);
        transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
        position: absolute;
        right: -40px;
        top: 20px;
        z-index: 10;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        text-shadow: 0 0 10px rgba(0, 230, 118, 0.65);
        writing-mode: vertical-rl;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 180px;
    }
    #wildcardToggle:hover {
        transform: translateX(5px);
        box-shadow: 0 0 38px rgba(0, 230, 118, 0.55);
        background: rgba(12, 12, 18, 0.98);
    }
    .wildcard-control {
        position: absolute;
        right: -40px;
        top: 20px;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        z-index: 99999;
    }
    .wildcard-toggle-vertical {
        position: absolute;
        left: 0;
        top: 0;
        width: 48px;
        min-height: 220px;
        padding: 16px 10px;
        border-radius: 28px;
        border: none;
        background: linear-gradient(180deg, #ffd966 0%, #f7b733 100%);
        color: #111;
        font-size: 0.92rem;
        font-weight: 900;
        writing-mode: vertical-rl;
        text-orientation: upright;
        letter-spacing: 0.18em;
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }
    .wildcard-toggle-vertical:hover {
        transform: translateY(-1px) scale(1.02);
        box-shadow: 0 24px 45px rgba(0, 0, 0, 0.3);
    }
    .wildcard-menu {
        display: none;
        position: absolute;
        left: 100%;
        top: 80px;
        margin-left: 15px;
        min-width: 260px;
        background: rgba(12, 12, 12, 0.98);
        padding: 22px;
        border-radius: 22px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 28px 70px rgba(0, 0, 0, 0.45);
        text-align: left;
        z-index: 99999;
    }
    .wildcard-menu.visible {
        display: block;
        animation: fadeInScale 0.22s ease-out forwards;
    }
    @keyframes fadeInScale {
        from { opacity: 0; transform: translateY(-10px) scale(0.96); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }
    .wildcard-header {
        color: #f4f4f4;
        margin-bottom: 16px;
        font-weight: 700;
        font-size: 1rem;
    }
    .wildcard-actions {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    .wildcard-action {
        background: #111;
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: #fff;
        padding: 14px 18px;
        border-radius: 16px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    }
    .wildcard-action:hover:not(:disabled) {
        transform: translateY(-1px);
        border-color: rgba(255, 145, 0, 0.9);
        background: #1f1f1f;
    }
    .wildcard-action:disabled {
        opacity: 0.45;
        cursor: not-allowed;
    }
    .wildcard-message {
        color: #ffcc4d;
        margin-top: 16px;
        font-weight: 700;
        min-height: 22px;
    }
    .answer-btn.fade-out-disabled {
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.6s ease;
    }
    .answer-btn.answer-correct {
        background: #00c853;
        color: #000;
        border-color: #00e676;
        box-shadow: 0 0 0 3px rgba(0, 200, 83, 0.18);
        transition: background-color 0.45s ease, transform 0.3s ease;
    }
    .answer-btn.answer-correct:hover {
        transform: scale(1.02);
    }
    .fade-out-card {
        animation: fadeOutCard 0.32s ease forwards;
    }
    @keyframes fadeOutCard {
        to {
            opacity: 0;
            transform: scale(0.98);
        }
    }
</style>

<main class="arcade-wrapper" style="flex-direction: column; position: relative;"> 
    <div style="text-align: center; margin-bottom: 20px; color: white;">
        <h3 style="font-size: 1.8rem; font-weight: bold; background: rgba(124, 77, 255, 0.3); 
        padding: 10px 20px; border-radius: 50px; display: inline-block;">
            Racha Actual: {{puntaje}}
        </h3>
    </div>

    <div style="text-align: center; margin-bottom: 15px; color: white; position: relative; display: flex; justify-content: center;">
        <div id="timerContainer" style="display: flex; align-items: center; justify-content: center;">
            <h4 id="timer" style="font-size: 1.5rem; font-weight: bold; color: #ff5252; margin: 0;">Tiempo: --</h4>
            <span id="timerBonus" class="timer-bonus"></span>
        </div>
    </div>

    <div class="arcade-card" style="border:4px solid {{color}}; position: relative !important; overflow: visible !important;">
        <div class="categoria-container">
            <span class="categoria-chip" style="background: {{color}}">
                {{tipo}}
            </span>
        </div>
        <h2 style="margin-bottom: 25px; font-size: 1.5rem; color: white;">{{pregunta}}</h2>

        <form id="answerForm" action="/tpfinal_mvc/Game/validarRespuesta" method="POST">
            <input type="hidden" name="id_pregunta" value="{{id_pregunta}}">
            <input type="hidden" id="remainingTimeInput" name="tiempo_restante" value="{{tiempo_limite}}">
            <div id="answerOptions">
                {{#opciones}}
                    <button type="submit" name="id_respuesta" value="{{id}}" class="arcade-btn answer-btn" data-answer-id="{{id}}">
                        {{texto}}
                    </button>
                {{/opciones}}
            </div>
        </form>
        {{#mensaje}}
        <div class="succesMessage">
            {{mensaje}}
        </div>
        {{/mensaje}}
        <button id="reportBtn" class="report-btn" type="button">
        <i class="bi bi-exclamation-triangle-fill"></i>
        </button>

        <div id="reportModal" class="report-modal">
        <div class="report-box">
            <button class="close-report" id="closeReport">
                <i class="bi bi-x-lg"></i>
            </button>
            <h3>Reportar pregunta</h3>
            <p>
                ¿Encontraste un error en esta pregunta?
            </p>
            <form action="/tpfinal_mvc/Game/reportarPregunta" method="POST">
                <input
                    type="hidden"
                    name="id_pregunta"
                    value="{{id_pregunta}}">
                <textarea
                    name="mensaje"
                    rows="5"
                    placeholder="Escribí el motivo (opcional)...">
                </textarea>
                <div class="report-actions">
                    <button
                        type="button"
                        id="cancelReport"
                        class="btn-report secondary">
                        Cancelar
                    </button>
                    <button
                        type="submit"
                        class="btn-report primary">
                        Enviar reporte
                    </button>
                </div>
            </form>
        </div>
        </div>

        <div class="wildcard-control">
            <button id="wildcardToggle" type="button" class="naza-toggle-btn">
                COMODINES
            </button>
            <div id="wildcardMenu" class="wildcard-menu">
                <div class="wildcard-header">Saldo disponible: {{coins}} 🪙</div>
                <div class="wildcard-actions">
                    <button id="wildcardResolution" class="wildcard-action arcade-btn" data-action="resolution" {{#comodin_magic_used}}disabled{{/comodin_magic_used}}>
                        ✨ Resolución Mágica (10 🪙)
                    </button>
                    <button id="wildcardChange" class="wildcard-action arcade-btn" data-action="change" {{#comodin_change_used}}disabled{{/comodin_change_used}}>
                        🔄 Cambiar Pregunta (2 🪙)
                    </button>
                    <button id="wildcard5050" class="wildcard-action arcade-btn" data-action="5050" {{#comodin_5050_used}}disabled{{/comodin_5050_used}}>
                        🌓 50/50 (2 🪙)
                    </button>
                </div>
                <div id="wildcardMessage" class="wildcard-message"></div>
            </div>
        </div>
    </div>
</main>

<script>
window.addEventListener('DOMContentLoaded', () => {
    let tiempo = parseInt("{{tiempo_limite}}") || 60;
    const timerDiv = document.getElementById('timer');
    const timerBonus = document.getElementById('timerBonus');
    const answerForm = document.getElementById('answerForm');
    const remainingTimeInput = document.getElementById('remainingTimeInput');
    const showTimeBonus = {{#show_time_bonus}}true{{/show_time_bonus}}{{^show_time_bonus}}false{{/show_time_bonus}};

    function actualizarTimer() {
        timerDiv.innerText = "Tiempo: " + tiempo;
    }

    function mostrarBonus() {
        timerBonus.textContent = '+25';
        timerBonus.classList.add('visible');
        setTimeout(() => {
            timerBonus.classList.remove('visible');
        }, 1500);
    }

    function iniciarCuentaRegresiva() {
        actualizarTimer();
        const intervalo = setInterval(() => {
            tiempo--;
            actualizarTimer();

            if (tiempo <= 0) {
                clearInterval(intervalo);
                window.location.href = '/tpfinal_mvc/Game/timeout';
            }
        }, 1000);
    }

    answerForm?.addEventListener('submit', () => {
        if (remainingTimeInput) {
            remainingTimeInput.value = tiempo;
        }
    });

    if (showTimeBonus) {
        mostrarBonus();
    }

    iniciarCuentaRegresiva();

    const wildcardToggle = document.getElementById('wildcardToggle');
    const wildcardMenu = document.getElementById('wildcardMenu');
    const wildcardMessage = document.getElementById('wildcardMessage');
    const answerOptions = document.getElementById('answerOptions');

    if (wildcardToggle && wildcardMenu) {
        wildcardToggle.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            wildcardMenu.classList.toggle('visible');
        });
    }

    document.querySelectorAll('.wildcard-action').forEach(button => {
        button.addEventListener('click', async (e) => {
            e.preventDefault();
            const action = button.dataset.action;
            if (!action || button.disabled) return;

            button.disabled = true;
            wildcardMessage.textContent = 'Procesando...';

            const formData = new URLSearchParams();
            formData.append('tiempo_restante', tiempo);

            let endpoint = '';
            if (action === '5050') {
                endpoint = 'useWildcard5050';
            } else if (action === 'change') {
                endpoint = 'useWildcardChange';
            } else if (action === 'resolution') {
                endpoint = 'useWildcardResolution';
            } else {
                wildcardMessage.textContent = 'Acción inválida.';
                button.disabled = false;
                return;
            }

            const response = await fetch(`/tpfinal_mvc/Game/${endpoint}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'Accept': 'application/json'
                },
                body: formData
            });

            const result = await response.json();
            if (!result.success) {
                button.disabled = false;
                wildcardMessage.textContent = result.error || 'Error inesperado';
                return;
            }

            if (wildcardToggle) {
                wildcardToggle.textContent = `Comodines (${result.coins} 🪙)`;
            }

            if (result.type === 'change') {
                wildcardMessage.textContent = 'Cambiando...';
                document.querySelector('.arcade-card')?.classList.add('fade-out-card');
                setTimeout(() => window.location.reload(), 320);
                return;
            }

            if (result.type === 'resolution') {
                document.querySelectorAll('.answer-btn').forEach(answerBtn => {
                    answerBtn.classList.remove('answer-correct');
                });
                const correctBtn = document.querySelector(`.answer-btn[data-answer-id="${result.correctId}"]`);
                if (correctBtn) {
                    correctBtn.classList.add('answer-correct');
                }
                wildcardMessage.textContent = 'Resolución Mágica aplicada.';
                return;
            }

            if (result.type === '5050') {
                document.querySelectorAll('.answer-btn').forEach(answerBtn => {
                    answerBtn.classList.remove('incorrect-option', 'answer-correct');
                    answerBtn.disabled = false;
                });

                if (Array.isArray(result.disabledIds)) {
                    result.disabledIds.forEach(id => {
                        const btn = document.querySelector(`.answer-btn[data-answer-id="${id}"]`);
                        if (btn) {
                            btn.classList.add('fade-out-disabled');
                            btn.disabled = true;
                        }
                    });
                }

                wildcardMessage.textContent = '50/50 aplicado: opciones incorrectas deshabilitadas.';
            }
        });
    });
});

// Modal de reportar pregunta
const reportBtn = document.getElementById("reportBtn");
const reportModal = document.getElementById("reportModal");
const closeReport = document.getElementById("closeReport");
const cancelReport = document.getElementById("cancelReport");

reportBtn.addEventListener("click", () => {
    reportModal.classList.add("active");
});

function cerrarModal(){
    reportModal.classList.remove("active");
}

closeReport.addEventListener("click", cerrarModal);
cancelReport.addEventListener("click", cerrarModal);

//Cerrar haciendo click afuera

reportModal.addEventListener("click",(e)=>{

    if(e.target===reportModal){
        cerrarModal();
    }

});

//Cerrar con ESC

document.addEventListener("keydown",(e)=>{

    if(e.key==="Escape"){
        cerrarModal();
    }

});
</script>
{{>footer}}
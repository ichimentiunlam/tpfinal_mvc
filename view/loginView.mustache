{{>header}}
<div class="container">
    <h2>Acceder</h2>
    {{#error}}
    <div class="panel" style="background: rgba(255, 119, 119, 0.12); border-color: #ff7675; color: #ffeaa7; margin-bottom: 20px;">
        {{error}}
    </div>
    {{/error}}
    <form action="/tpfinal_mvc/game/procesarLogin" method="POST">
        <div class="form-group">
            <label for="email">Correo electrónico</label>
            <input type="email" id="email" name="email" value="{{email}}" placeholder="jugador@arcade.com" required>
        </div>
        <div class="form-group">
            <label for="password">Contraseña</label>
            <input type="password" id="password" name="password" placeholder="Tu contraseña" required>
        </div>
        <button type="submit" class="btn-submit">🔐 Entrar al arcade</button>
        <a href="/tpfinal_mvc/game/registro" class="back-link">← Crear cuenta nueva</a>
    </form>
</div>
{{>footer}}

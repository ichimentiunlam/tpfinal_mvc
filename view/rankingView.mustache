{{>header}}
<link rel="stylesheet" href="/tpfinal_mvc/assets/Css/game.css">

<style>
    .ranking-page {
        max-width: 1080px;
        margin: 40px auto;
        padding: 24px;
        color: #f4f4f4;
    }

    .ranking-card {
        background: rgba(10, 10, 16, 0.94);
        border: 1px solid rgba(124, 77, 255, 0.28);
        border-radius: 28px;
        box-shadow: 0 28px 70px rgba(0, 0, 0, 0.32);
        overflow: hidden;
    }

    .ranking-header {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 28px 32px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .ranking-title {
        margin: 0;
        font-size: 2rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #fff;
    }

    .ranking-subtitle {
        margin: 6px 0 0;
        color: rgba(255, 255, 255, 0.72);
        font-size: 0.95rem;
        max-width: 560px;
        line-height: 1.6;
    }

    .ranking-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 460px;
    }

    .ranking-table th,
    .ranking-table td {
        padding: 18px 22px;
        text-align: left;
    }

    .ranking-table th {
        font-size: 0.86rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.8);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .ranking-table tbody tr {
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        transition: background 0.2s ease, transform 0.2s ease;
    }

    .ranking-table tbody tr:hover {
        background: rgba(255, 255, 255, 0.04);
        transform: translateX(2px);
    }

    .rank-number {
        width: 100px;
        font-weight: 800;
        color: #c7c3ff;
    }

    .player-name {
        font-weight: 700;
        color: #fff;
    }

    .score {
        font-weight: 800;
        text-align: right;
        color: #f4f4f4;
    }

    .podium-1 {
        background: radial-gradient(circle at top left, rgba(255, 215, 0, 0.18), transparent 55%);
        border-left: 4px solid #ffd700;
        box-shadow: inset 0 0 26px rgba(255, 215, 0, 0.12);
    }

    .podium-2 {
        background: radial-gradient(circle at top left, rgba(192, 192, 192, 0.16), transparent 55%);
        border-left: 4px solid #c0c0c0;
        box-shadow: inset 0 0 26px rgba(192, 192, 192, 0.10);
    }

    .podium-3 {
        background: radial-gradient(circle at top left, rgba(205, 127, 50, 0.16), transparent 55%);
        border-left: 4px solid #cd7f32;
        box-shadow: inset 0 0 26px rgba(205, 127, 50, 0.10);
    }

    .podium-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 36px;
        height: 36px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 0.95rem;
        color: #111;
        margin-right: 12px;
    }

    .podium-badge.gold {
        background: #ffd700;
    }

    .podium-badge.silver {
        background: #c0c0c0;
    }

    .podium-badge.bronze {
        background: #cd7f32;
    }

    .empty-state {
        padding: 40px 32px;
        text-align: center;
        color: rgba(255, 255, 255, 0.72);
        font-size: 1rem;
    }

    @media (max-width: 720px) {
        .ranking-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .ranking-table th,
        .ranking-table td {
            padding: 14px 14px;
        }

        .score {
            text-align: left;
        }
    }
</style>

<main class="ranking-page">
    <div class="ranking-card">
        <div class="ranking-header">
            <div>
                <h1 class="ranking-title">Ranking</h1>
                <p class="ranking-subtitle">Los mejores 10 jugadores del arcade. Mantén tu racha y asciende en la tabla.</p>
            </div>
        </div>

        <table class="ranking-table">
            <thead>
                <tr>
                    <th>Posición</th>
                    <th>Jugador</th>
                    <th><a href="?sort=respuestas&order={{orderRespuestas}}" style="color: inherit; text-decoration: underline;">Respuestas Totales</a></th>
                    <th><a href="?sort=racha&order={{orderRacha}}" style="color: inherit; text-decoration: underline;">Racha Máxima</a></th>
                </tr>
            </thead>
            <tbody>
                {{#usuariosRanking}}
                <tr class="{{rankClass}}">
                    <td class="rank-number">
                        <span class="podium-badge {{badgeClass}}">{{rank}}</span>
                    </td>
                    <td class="player-name">
                        <a href="/tpfinal_mvc/User/verPerfil?id={{id}}" style="color: inherit; text-decoration: underline;">{{usuario}}</a>
                    </td>
                    <td class="score">{{respuestas_totales}}</td>
                    <td class="score">{{racha_max}}</td>
                </tr>
                {{/usuariosRanking}}
            </tbody>
        </table>

        {{^usuariosRanking}}
        <div class="empty-state">Aún no hay datos de ranking. Juega partidas para subir al top 10.</div>
        {{/usuariosRanking}}
    </div>
</main>

{{>footer}}
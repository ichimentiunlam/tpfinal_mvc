{{>header}}
<link rel="stylesheet" href="/tpfinal_mvc/assets/Css/register.css">
<div class="validateContainer">
    <h2>Verificación de correo</h2>
    <div>
        <p>{{message}}</p>
        <p>Ingrésalo abajo para activar tu cuenta <strong>{{email}}</strong>.</p>

        <form action="/tpfinal_mvc/User/validarCorreo" method="POST" class="registerForm">
            <input type="hidden" name="email" value="{{email}}">
            <label for="code">Código de verificación</label>
            <input type="text" id="code" name="code" maxlength="6" placeholder="Ej: 123456" required>
            <button type="submit" class="btn primary">Validar correo</button>
        </form>

        <a href="/tpfinal_mvc/User/home" class="btn secondary">Volver al inicio</a>
    </div>
</div>
{{>footer}}

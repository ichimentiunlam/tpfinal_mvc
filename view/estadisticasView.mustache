{{>header}}
<link rel="stylesheet" href="/tpfinal_mvc/assets/Css/estadisticasView.css">
<main class="estadisticasContainer">

    <div class="statsTop no-print">
        <h1>Estadísticas</h1>

        <div class="tabs">
            <a href="?periodo=dia" class="{{#es_dia}}active{{/es_dia}}">Día</a>
            <a href="?periodo=semana" class="{{#es_semana}}active{{/es_semana}}">Semana</a>
            <a href="?periodo=mes" class="{{#es_mes}}active{{/es_mes}}">Mes</a>
            <a href="?periodo=anio" class="{{#es_anio}}active{{/es_anio}}">Año</a>
            <a href="?periodo=todo" class="{{#es_todo}}active{{/es_todo}}">Todo</a>
        </div>

        <div class="statsActions">
            <button class="btn-report primary" onclick="window.print()">Imprimir</button>
            <a class="btn-report primary" href="/tpfinal_mvc/Admin/estadisticasPdf?periodo={{periodo}}" target="_blank">Generar PDF</a>
        </div>
    </div>

    <div class="kpisGrid">
        <div class="kpiCard"><span>{{cantidad_jugadores}}</span><label>Jugadores totales</label></div>
        <div class="kpiCard"><span>{{cantidad_partidas}}</span><label>Partidas jugadas</label></div>
        <div class="kpiCard"><span>{{cantidad_preguntas}}</span><label>Preguntas en el juego</label></div>
        <div class="kpiCard"><span>{{cantidad_preguntas_creadas}}</span><label>Preguntas sugeridas</label></div>
        <div class="kpiCard"><span>{{cantidad_usuarios_nuevos}}</span><label>Usuarios nuevos</label></div>
    </div>

    <div class="statsSecciones">

        <section class="statsSection">
            <h2>% de aciertos por usuario</h2>
            <div class="tablaStats">
                <div class="statsGrid statsGridAciertos head">
                    <div>Usuario</div>
                    <div>Respondidas</div>
                    <div>Correctas</div>
                    <div>%</div>
                </div>
                {{#aciertos_por_usuario}}
                <div class="statsGrid statsGridAciertos fila">
                    <div>{{usuario}}</div>
                    <div>{{preguntas_respondidas}}</div>
                    <div>{{preguntas_correctas}}</div>
                    <div>{{porcentaje}}%</div>
                </div>
                {{/aciertos_por_usuario}}
            </div>
        </section>

        <div class="statsColumna">

            <section class="statsSection">
                <h2>Usuarios por país</h2>
                <div class="tablaStats">
                    <div class="statsGrid statsGridDos head">
                        <div>País</div>
                        <div>Cantidad</div>
                    </div>
                    {{#usuarios_por_pais}}
                    <div class="statsGrid statsGridDos fila">
                        <div>{{pais}}</div>
                        <div>{{cantidad}}</div>
                    </div>
                    {{/usuarios_por_pais}}
                </div>
            </section>

            <section class="statsSection">
                <h2>Usuarios por sexo</h2>
                <div class="tablaStats">
                    <div class="statsGrid statsGridDos head">
                        <div>Sexo</div>
                        <div>Cantidad</div>
                    </div>
                    {{#usuarios_por_sexo}}
                    <div class="statsGrid statsGridDos fila">
                        <div>{{sexo}}</div>
                        <div>{{cantidad}}</div>
                    </div>
                    {{/usuarios_por_sexo}}
                </div>
            </section>

            <section class="statsSection">
                <h2>Usuarios por grupo de edad</h2>
                <div class="tablaStats">
                    <div class="statsGrid statsGridDos head">
                        <div>Grupo</div>
                        <div>Cantidad</div>
                    </div>
                    {{#usuarios_por_edad}}
                    <div class="statsGrid statsGridDos fila">
                        <div>{{grupo}}</div>
                        <div>{{cantidad}}</div>
                    </div>
                    {{/usuarios_por_edad}}
                </div>
            </section>

        </div>

    </div>
</main>
{{>footer}}
